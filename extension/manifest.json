{
  "manifest_version": 3,
  "name": "LDM — Download Manager",
  "version": "1.0.0",
  "description": "Detect videos and download links on any page and send them to LDM.",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "notifications",
    "webRequest",
    "tabs",
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:6543/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "LDM Downloads"
  }
}
